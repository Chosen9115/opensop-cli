#!/usr/bin/env bash
#
# opensop — thin CLI client for OpenSOP runtimes
#
# Talks to any OpenSOP server's /sop/* HTTP API. Stateless except for a
# small local cache that maps instance IDs back to process names so most
# commands can take just an id.
#
# Usage:  opensop <command> [args]
# Help:   opensop help
# Repo:   https://github.com/Chosen9115/opensop-cli

set -euo pipefail

# --------------------------------------------------------------------------- #
# Constants & paths
# --------------------------------------------------------------------------- #

readonly OPENSOP_CLI_VERSION="0.5.0"
readonly OPENSOP_HOME="${OPENSOP_HOME:-$HOME/.opensop}"
readonly CONFIG_FILE="$OPENSOP_HOME/config"
readonly CACHE_FILE="$OPENSOP_HOME/instances.tsv"

# --------------------------------------------------------------------------- #
# Output helpers
# --------------------------------------------------------------------------- #

is_tty() { [[ -t 1 ]]; }

# Color support — only when stdout is a TTY and NO_COLOR is unset.
if is_tty && [[ -z "${NO_COLOR:-}" ]]; then
  C_RESET=$'\033[0m'
  C_BOLD=$'\033[1m'
  C_DIM=$'\033[2m'
  C_RED=$'\033[31m'
  C_GREEN=$'\033[32m'
  C_YELLOW=$'\033[33m'
  C_BLUE=$'\033[34m'
  C_CYAN=$'\033[36m'
else
  C_RESET=""; C_BOLD=""; C_DIM=""; C_RED=""; C_GREEN=""
  C_YELLOW=""; C_BLUE=""; C_CYAN=""
fi

# _resolve_output_mode
#   Returns the effective output mode: "json" or "pretty".
#   --json flag sets OUTPUT_MODE="json"; --pretty sets "pretty".
#   "auto" (default before main strips flags) resolves TTY-aware.
_resolve_output_mode() {
  local mode="$OUTPUT_MODE"
  if [[ "$mode" == "auto" ]]; then
    is_tty && mode="pretty" || mode="json"
  fi
  echo "$mode"
}

# _error_mode
#   Returns "json" only when --json was explicitly requested (OUTPUT_MODE="json").
#   "auto" always resolves to prose for error messages — errors are human-readable
#   by default; agents opt in with --json.
_error_mode() {
  if [[ "$OUTPUT_MODE" == "json" ]]; then
    echo "json"
  else
    echo "prose"
  fi
}

# err MESSAGE [CODE [HINT]]
#   Print an error. In JSON mode emits {error, message, hint?} to stderr.
#   In prose mode prints the familiar colored "opensop: ..." line.
err() {
  local message="$1" code="${2:-cli_error}" hint="${3:-}"
  local mode; mode=$(_error_mode)
  if [[ "$mode" == "json" ]]; then
    jq -nc --arg error "$code" --arg msg "$message" --arg hint "$hint" \
      '{error: $error, message: $msg} + (if $hint != "" then {hint: $hint} else {} end)' >&2
  else
    printf '%sopensop:%s %s\n' "$C_RED" "$C_RESET" "$message" >&2
  fi
}

warn() { printf '%sopensop:%s %s\n' "$C_YELLOW" "$C_RESET" "$*" >&2; }
ok()   { printf '%s✓%s %s\n' "$C_GREEN" "$C_RESET" "$*"; }
info() { printf '%s%s%s\n' "$C_DIM" "$*" "$C_RESET"; }

# die MESSAGE [CODE [HINT]]
die() { err "$@"; exit 1; }

# Output mode: pretty | json. Set by --json / --pretty flags or auto-detected.
OUTPUT_MODE="auto"
LOCAL_MODE=false                                                  # --local: run against internal files (no server)
# Local run receipts. v0.6: when inside an OpenSOP cell, the default becomes
# the active cell's .opensop/ instead of the global ~/.opensop-local — so
# receipts land alongside the processes that produced them. The explicit
# env override (when the user sets OPENSOP_LOCAL_HOME themselves) always
# wins. The cell-aware override is applied in main() after helpers are
# loaded; here we just track whether the user set it explicitly.
if [[ -n "${OPENSOP_LOCAL_HOME-}" ]]; then
  _OPENSOP_LOCAL_HOME_EXPLICIT=true
else
  _OPENSOP_LOCAL_HOME_EXPLICIT=false
fi
OPENSOP_LOCAL_HOME="${OPENSOP_LOCAL_HOME:-$HOME/.opensop-local}"

emit_json() {
  # Print compact JSON (stdin) — used for --json and piped output.
  jq -c .
}

emit_pretty_or_json() {
  # If TTY and not --json, pretty-print. Else compact JSON.
  local mode; mode=$(_resolve_output_mode)
  if [[ "$mode" == "json" ]]; then
    jq -c .
  else
    jq .
  fi
}

# --------------------------------------------------------------------------- #
# Dependency check
# --------------------------------------------------------------------------- #

require_jq() {
  command -v jq >/dev/null 2>&1 || die "jq is required — install it first" "missing_dependency" "brew install jq"
}

require_curl() {
  command -v curl >/dev/null 2>&1 || die "curl is required (it should be on every Unix already)" "missing_dependency"
}

# --------------------------------------------------------------------------- #
# Config — ~/.opensop/config is sourced as bash key=value pairs.
# Vars: OPENSOP_URL, OPENSOP_TOKEN
# --------------------------------------------------------------------------- #

ensure_home() {
  mkdir -p "$OPENSOP_HOME"
  chmod 700 "$OPENSOP_HOME"
}

load_config() {
  ensure_home
  if [[ -f "$CONFIG_FILE" ]]; then
    # shellcheck source=/dev/null
    source "$CONFIG_FILE"
  fi
  # Env vars override config file.
  : "${OPENSOP_URL:=${OPENSOP_URL_OVERRIDE:-}}"
  : "${OPENSOP_TOKEN:=${OPENSOP_TOKEN_OVERRIDE:-}}"
}

save_config() {
  ensure_home
  umask 077
  cat > "$CONFIG_FILE" <<EOF
# OpenSOP CLI config — managed by 'opensop config'
# Override either of these via env vars (OPENSOP_URL / OPENSOP_TOKEN) at runtime.
OPENSOP_URL="${OPENSOP_URL:-}"
OPENSOP_TOKEN="${OPENSOP_TOKEN:-}"
EOF
  chmod 600 "$CONFIG_FILE"
}

require_url() {
  [[ -n "${OPENSOP_URL:-}" ]] || die "OPENSOP_URL is not set — run: opensop config set url <https://your-server>" "config_missing" "opensop config set url <URL>"
}

# --------------------------------------------------------------------------- #
# HTTP — every API call goes through these.
#
# api_call METHOD PATH [BODY]
#   - prints response body to stdout
#   - exits non-zero on HTTP >= 400 (with error printed to stderr)
# --------------------------------------------------------------------------- #

api_call() {
  local method="$1"; local path="$2"; local body="${3:-}"
  require_url
  local url="${OPENSOP_URL%/}${path}"
  local tmp_body
  tmp_body=$(mktemp)

  local -a curl_args=(
    -sS
    -X "$method"
    -H "Content-Type: application/json"
    -H "Accept: application/json"
    -o "$tmp_body"
    -w "%{http_code}"
  )

  [[ -n "${OPENSOP_TOKEN:-}" ]] && curl_args+=(-H "X-SOP-Token: $OPENSOP_TOKEN")
  [[ -n "$body" ]] && curl_args+=(-d "$body")

  local status
  if ! status=$(curl "${curl_args[@]}" "$url"); then
    rm -f "$tmp_body"
    die "request failed: $method $url" "network_error"
  fi

  if [[ "$status" -ge 400 ]]; then
    local emode; emode=$(_error_mode)
    if [[ "$emode" == "json" ]]; then
      # In JSON mode: pass through the server's error envelope verbatim,
      # augmented with _meta.http_status for round-trip context.
      jq -c --argjson s "$status" '. + {_meta: {http_status: $s}}' "$tmp_body" >&2 \
        2>/dev/null || jq -nc --argjson s "$status" \
          '{error: "http_error", message: "HTTP error", _meta: {http_status: $s}}' >&2
    else
      local err_msg err_code
      err_code=$(jq -r '.error // "http_error"' "$tmp_body" 2>/dev/null || echo "http_error")
      err_msg=$(jq -r '.message // empty' "$tmp_body" 2>/dev/null || echo "")
      printf '%sopensop:%s HTTP %s — %s%s\n' "$C_RED" "$C_RESET" "$status" "$err_code" \
        "${err_msg:+: $err_msg}" >&2
    fi
    rm -f "$tmp_body"
    exit 1
  fi
  cat "$tmp_body"
  rm -f "$tmp_body"
}

api_get()  { api_call GET  "$1"; }
api_post() { api_call POST "$1" "${2:-{\}}"; }

# --------------------------------------------------------------------------- #
# Local instance cache — TSV: id\tname\tcreated_at\turl
# Lets `opensop status <id>` work without re-passing the process name.
# --------------------------------------------------------------------------- #

cache_instance() {
  local id="$1" name="$2"
  ensure_home
  touch "$CACHE_FILE"
  # Drop existing row for this id (if any), then append fresh.
  grep -v "^${id}	" "$CACHE_FILE" > "${CACHE_FILE}.tmp" 2>/dev/null || true
  printf '%s\t%s\t%s\t%s\n' "$id" "$name" "$(date -u +%Y-%m-%dT%H:%M:%SZ)" "${OPENSOP_URL:-}" >> "${CACHE_FILE}.tmp"
  mv "${CACHE_FILE}.tmp" "$CACHE_FILE"
}

lookup_name() {
  # Resolve instance id → process name. Cache first, then paginated /sop/instances scan.
  local id="$1"
  if [[ -f "$CACHE_FILE" ]]; then
    local hit
    hit=$(awk -F'\t' -v id="$id" '$1 == id { print $2; exit }' "$CACHE_FILE")
    [[ -n "$hit" ]] && { echo "$hit"; return 0; }
  fi
  # Cache miss — paginate up to 1000 rows (5 pages of 200) looking for the id.
  warn "id $id not in local cache; scanning /sop/instances..."
  local name=""
  for offset in 0 200 400 600 800; do
    local resp count
    resp=$(api_get "/sop/instances?limit=200&offset=$offset")
    name=$(echo "$resp" | jq -r --arg id "$id" '.instances[] | select(.id == $id) | .process.name' | head -1)
    if [[ -n "$name" ]]; then
      cache_instance "$id" "$name"
      echo "$name"
      return 0
    fi
    count=$(echo "$resp" | jq -r '.instances | length')
    # Short page = end of results; no need to keep paging.
    [[ "$count" -lt 200 ]] && break
  done
  die "instance $id not found on $OPENSOP_URL (check the id, or set --state and re-list with 'opensop instances')" "instance_not_found"
}

# --------------------------------------------------------------------------- #
# Cell / scope (v0.6 — fractal addressing)
#
# A "cell" is a directory marked by .opensop/manifest.yaml. Cells nest;
# `init` creates one in cwd, `scope` walks up from cwd to find the nearest
# cell (the active scope) and prints its ancestor chain.
#
# Substrate level only — no policy, no evolution semantics here. The
# manifest is intentionally tiny (name + parent) so a 6-line grep+sed
# parser is enough and we don't pull in a yaml dep.
# --------------------------------------------------------------------------- #

# _find_scope_root [start_dir]
#   Walk up from start_dir (default: cwd) looking for .opensop/manifest.yaml.
#   Echo absolute path of the cell root (the directory CONTAINING .opensop/),
#   or empty string if none. Empty is "no active cell", not an error.
_find_scope_root() {
  local d
  d="$(cd "${1:-.}" 2>/dev/null && pwd)" || return 0
  while [[ "$d" != "/" && -n "$d" ]]; do
    if [[ -d "$d/.opensop" && -f "$d/.opensop/manifest.yaml" ]]; then
      echo "$d"
      return 0
    fi
    d="$(dirname "$d")"
  done
  return 0
}

# _read_manifest_field <cell_root> <field>
#   Read a single top-level scalar field from .opensop/manifest.yaml.
#   Grammar: "field: value" on its own line. Strips quotes + trailing space.
#   Returns empty for "null" or missing fields.
_read_manifest_field() {
  local cell_root="$1" field="$2"
  local file="$cell_root/.opensop/manifest.yaml"
  local val
  [[ -f "$file" ]] || return 0
  val=$(grep -E "^${field}:" "$file" 2>/dev/null \
    | head -1 \
    | sed -E "s/^${field}:[[:space:]]*//; s/^['\"]//; s/['\"]$//; s/[[:space:]]+$//")
  [[ "$val" == "null" ]] && val=""
  echo "$val"
}

# _enumerate_ancestors <cell_root>
#   Echo nearest-first list of ancestor cell roots, one per line.
#   Resolves the manifest's `parent` field (relative or absolute), then
#   continues up the chain until a manifest is missing or parent is null.
_enumerate_ancestors() {
  local cell_root="$1"
  local parent_path
  while true; do
    parent_path="$(_read_manifest_field "$cell_root" parent)"
    [[ -z "$parent_path" ]] && return 0
    if [[ "$parent_path" != /* ]]; then
      parent_path="$(cd "$cell_root/$parent_path" 2>/dev/null && pwd)" || return 0
    fi
    [[ -d "$parent_path/.opensop" && -f "$parent_path/.opensop/manifest.yaml" ]] || return 0
    echo "$parent_path"
    cell_root="$parent_path"
  done
}

# opensop init [--name NAME] [--parent PATH]
#   Create .opensop/ in cwd. The directory becomes the active cell for any
#   OpenSOP operation executed from within it (or any subdirectory).
#
#   Defaults:
#     --name      cwd basename
#     --parent    auto-detected by walking up from cwd's parent for an
#                 ancestor cell; null if none found
cmd_init() {
  local name="" parent_arg="" explicit_parent=false
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --name)   name="$2"; shift 2 ;;
      --parent) parent_arg="$2"; explicit_parent=true; shift 2 ;;
      *) die "unknown flag for init: $1" "unknown_flag" "run opensop help" ;;
    esac
  done

  local cwd; cwd="$(pwd)"

  if [[ -d "$cwd/.opensop" ]]; then
    die "cell already initialized at $cwd/.opensop" "usage_error" \
        "remove .opensop/ first if you want to re-init, or cd elsewhere"
  fi

  [[ -z "$name" ]] && name="$(basename "$cwd")"

  local parent_resolved=""
  if $explicit_parent; then
    parent_resolved="$parent_arg"
  else
    local up; up="$(_find_scope_root "$(dirname "$cwd")")"
    if [[ -n "$up" ]]; then
      if [[ "$up" == "$(dirname "$cwd")" ]]; then
        parent_resolved="../"
      else
        parent_resolved="$up"
      fi
    fi
  fi

  mkdir -p "$cwd/.opensop/runs" "$cwd/.opensop/archive"
  {
    echo "name: $name"
    if [[ -n "$parent_resolved" ]]; then
      echo "parent: $parent_resolved"
    else
      echo "parent: null"
    fi
  } > "$cwd/.opensop/manifest.yaml"
  echo "{}" > "$cwd/.opensop/lineage.json"

  if [[ "$OUTPUT_MODE" == "pretty" ]] || { [[ "$OUTPUT_MODE" == "auto" ]] && is_tty; }; then
    info "${C_GREEN}initialized cell '$name'${C_RESET} at $cwd/.opensop/"
    if [[ -n "$parent_resolved" ]]; then
      info "  parent: $parent_resolved"
    else
      info "  parent: (root cell — no ancestor)"
    fi
  else
    jq -nc --arg root "$cwd" --arg name "$name" --arg parent "$parent_resolved" \
      '{ok:true, cell_root:$root, name:$name, parent:(if $parent == "" then null else $parent end)}'
  fi
}

# opensop scope
#   Print the active cell + ancestor chain (nearest-first). Fails if cwd is
#   not inside any cell.
cmd_scope() {
  local cell_root; cell_root="$(_find_scope_root)"

  if [[ -z "$cell_root" ]]; then
    die "not inside an OpenSOP cell — run 'opensop init' to create one" "usage_error" \
        "or cd into a directory under an existing cell"
  fi

  local name; name="$(_read_manifest_field "$cell_root" name)"

  if [[ "$OUTPUT_MODE" == "pretty" ]] || { [[ "$OUTPUT_MODE" == "auto" ]] && is_tty; }; then
    info "${C_BOLD}active cell:${C_RESET} $name"
    info "  $cell_root"
    local printed_header=false
    while IFS= read -r ancestor_root; do
      [[ -z "$ancestor_root" ]] && continue
      $printed_header || { info ""; info "ancestors (nearest first):"; printed_header=true; }
      local a_name; a_name="$(_read_manifest_field "$ancestor_root" name)"
      info "  ↑ $a_name"
      info "    $ancestor_root"
    done < <(_enumerate_ancestors "$cell_root")
  else
    local payload
    payload="$(jq -n --arg name "$name" --arg root "$cell_root" \
      '[{name:$name, root:$root, active:true}]')"
    while IFS= read -r ancestor_root; do
      [[ -z "$ancestor_root" ]] && continue
      local a_name; a_name="$(_read_manifest_field "$ancestor_root" name)"
      payload="$(jq --arg name "$a_name" --arg root "$ancestor_root" \
        '. + [{name:$name, root:$root, active:false}]' <<<"$payload")"
    done < <(_enumerate_ancestors "$cell_root")
    echo "$payload"
  fi
}

# --------------------------------------------------------------------------- #
# Lineage (v0.6 — substrate-level event log per skill)
#
# Per-cell .opensop/lineage.json records `status` / `metadata` / `history`
# for every skill the cell knows about. The substrate stores; policies
# populate via `annotate` and read via `lineage`. Both `status` and
# `metadata` are open — the substrate does not interpret them.
#
# Schema (per skill, keyed by logical_name in the top-level object):
#   { logical_name, forked_from, history: [{at, type, data}], status, metadata }
# --------------------------------------------------------------------------- #

# _lineage_path <cell_root>  — echo absolute path of the cell's lineage.json
_lineage_path() { echo "$1/.opensop/lineage.json"; }

# _lineage_read <cell_root>
#   Echo lineage.json contents (or '{}' if file missing). Errors on bad JSON.
_lineage_read() {
  local f; f="$(_lineage_path "$1")"
  if [[ ! -f "$f" ]]; then
    echo "{}"
    return 0
  fi
  if ! jq -e . "$f" >/dev/null 2>&1; then
    die "corrupt lineage file: $f" "invalid_json" "remove or fix the file"
  fi
  cat "$f"
}

# _lineage_write <cell_root> <json>  — atomic write via temp + mv
_lineage_write() {
  local f; f="$(_lineage_path "$1")"
  local tmp="${f}.tmp.$$"
  printf '%s\n' "$2" > "$tmp"
  mv "$tmp" "$f"
}

# _lineage_default_entry <skill>  — echo the empty-default entry shape
_lineage_default_entry() {
  jq -nc --arg name "$1" \
    '{logical_name: $name, forked_from: null, history: [], status: "", metadata: {}}'
}

# opensop annotate <skill> <event-type> <json>
#   Append a policy event to the skill's lineage history in the active cell.
#   Creates the lineage entry with default fields if it doesn't exist yet.
#   Event type is open-string; data is whatever JSON the policy needs.
cmd_annotate() {
  [[ $# -lt 3 ]] && die "usage: opensop annotate <skill> <event-type> <json-data>" "usage_error" \
                        "example: opensop annotate publish-linkedin promote '{\"to\":\"m4\"}'"
  local skill="$1" event_type="$2" data_json="$3"

  if ! jq -e . <<<"$data_json" >/dev/null 2>&1; then
    die "invalid JSON data: $data_json" "invalid_json" \
        "wrap data in single quotes; ensure it parses (e.g. '{\"key\":\"value\"}')"
  fi

  local cell_root; cell_root="$(_find_scope_root)"
  [[ -z "$cell_root" ]] && die "not inside an OpenSOP cell — run 'opensop init' first" "usage_error" \
                               "or cd into a directory under an existing cell"

  local now; now="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  local lineage; lineage="$(_lineage_read "$cell_root")"

  # Existing entry, or fresh default.
  local entry; entry="$(jq -n --argjson l "$lineage" --arg s "$skill" '$l[$s] // null')"
  if [[ "$entry" == "null" ]]; then
    entry="$(_lineage_default_entry "$skill")"
  fi

  local event; event="$(jq -nc --arg at "$now" --arg type "$event_type" --argjson data "$data_json" \
    '{at: $at, type: $type, data: $data}')"
  local new_entry; new_entry="$(jq --argjson e "$event" '.history += [$e]' <<<"$entry")"
  local new_lineage; new_lineage="$(jq --arg s "$skill" --argjson e "$new_entry" '.[$s] = $e' <<<"$lineage")"

  _lineage_write "$cell_root" "$new_lineage"

  if [[ "$OUTPUT_MODE" == "pretty" ]] || { [[ "$OUTPUT_MODE" == "auto" ]] && is_tty; }; then
    info "${C_GREEN}annotated${C_RESET} '$skill' with event '$event_type' at $now"
  else
    echo "$event"
  fi
}

# opensop lineage <skill>
#   Print the lineage entry for a skill in the active cell. Returns the
#   default empty entry if no events have been recorded for that skill yet.
cmd_lineage() {
  [[ $# -lt 1 ]] && die "usage: opensop lineage <skill>" "usage_error" \
                        "name a skill (e.g., opensop lineage publish-linkedin)"
  local skill="$1"

  local cell_root; cell_root="$(_find_scope_root)"
  [[ -z "$cell_root" ]] && die "not inside an OpenSOP cell — run 'opensop init' first" "usage_error" \
                               "or cd into a directory under an existing cell"

  local lineage; lineage="$(_lineage_read "$cell_root")"
  local entry; entry="$(jq --arg s "$skill" '.[$s] // null' <<<"$lineage")"
  if [[ "$entry" == "null" ]]; then
    entry="$(_lineage_default_entry "$skill")"
  fi

  if [[ "$OUTPUT_MODE" == "pretty" ]] || { [[ "$OUTPUT_MODE" == "auto" ]] && is_tty; }; then
    local n_events status
    n_events="$(jq -r '.history | length' <<<"$entry")"
    status="$(jq -r '.status // ""' <<<"$entry")"
    [[ -z "$status" ]] && status="(none)"

    info "${C_BOLD}lineage:${C_RESET} $skill"
    info "  logical_name: $(jq -r '.logical_name' <<<"$entry")"
    info "  status:       $status"
    info "  metadata:     $(jq -c '.metadata' <<<"$entry")"
    info "  forked_from:  $(jq -c '.forked_from' <<<"$entry")"
    info "  history ($n_events event(s)):"
    if [[ "$n_events" == "0" ]]; then
      info "    (none)"
    else
      while IFS= read -r line; do info "$line"; done < <(jq -r '.history[] | "    \(.at)  \(.type)  \(.data | tojson)"' <<<"$entry")
    fi
  else
    jq . <<<"$entry"
  fi
}

# opensop fork <name> [--from <cell-path>]
#   Materialize a copy of an ancestor cell's skill in the active cell, and
#   record a lineage entry with the parent's policy state (status, metadata)
#   captured as a snapshot. After fork:
#     * processes/<name>.sop.json exists in the active cell (copied verbatim)
#     * lineage entry has forked_from = { cell, forked_at, snapshot }
#     * the child's live status + metadata are empty — policy decides what
#       to do with the snapshot (e.g., inherit + flag as unverified)
#
#   Default source: walk ancestors and use the nearest match. Pass --from
#   to override (resolves relative to the active cell or accepts absolute).
cmd_fork() {
  local name="" from_arg=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --from) from_arg="$2"; shift 2 ;;
      --*)    die "unknown flag for fork: $1" "unknown_flag" "run opensop help" ;;
      *)
        if [[ -z "$name" ]]; then name="$1"; shift
        else die "unexpected arg: $1" "usage_error" "usage: opensop fork <name> [--from <cell>]"
        fi
        ;;
    esac
  done
  [[ -z "$name" ]] && die "usage: opensop fork <name> [--from <cell-path>]" "usage_error" "name the skill to fork"

  local active_cell; active_cell="$(_find_scope_root)"
  [[ -z "$active_cell" ]] && die "not inside an OpenSOP cell — run 'opensop init' first" "usage_error" \
                                "create a cell first, then fork into it"

  # Refuse to overwrite — a fork into an active cell that already has the
  # skill would silently shadow without recording lineage. Force explicit
  # action from the user.
  [[ -f "$active_cell/processes/${name}.sop.json" ]] && \
    die "skill already exists in active cell: $active_cell/processes/${name}.sop.json" "usage_error" \
        "remove it first, or fork into a different cell"

  # Resolve source cell + file.
  local src_cell="" src_file=""
  if [[ -n "$from_arg" ]]; then
    if [[ "$from_arg" != /* ]]; then
      src_cell="$(cd "$active_cell/$from_arg" 2>/dev/null && pwd)" \
        || die "--from cell not found: $from_arg" "file_not_found" "use an existing cell path"
    else
      src_cell="$from_arg"
    fi
    [[ -d "$src_cell/.opensop" && -f "$src_cell/.opensop/manifest.yaml" ]] \
      || die "--from is not a cell: $src_cell" "usage_error" "the path must contain .opensop/manifest.yaml"
    src_file="$src_cell/processes/${name}.sop.json"
    [[ -f "$src_file" ]] || die "skill '$name' not found in $src_cell" "file_not_found" "check processes/${name}.sop.json"
  else
    while IFS= read -r anc; do
      [[ -z "$anc" ]] && continue
      if [[ -f "$anc/processes/${name}.sop.json" ]]; then
        src_cell="$anc"
        src_file="$anc/processes/${name}.sop.json"
        break
      fi
    done < <(_enumerate_ancestors "$active_cell")
    [[ -z "$src_file" ]] && die "skill '$name' not found in any ancestor cell" "file_not_found" \
                                "use --from to specify a non-ancestor cell"
  fi

  # Snapshot parent's policy state (status + metadata) — opaque to substrate.
  local parent_lineage parent_entry snapshot
  parent_lineage="$(_lineage_read "$src_cell")"
  parent_entry="$(jq -n --argjson l "$parent_lineage" --arg s "$name" '$l[$s] // null')"
  if [[ "$parent_entry" == "null" ]]; then
    snapshot='{"status":"","metadata":{}}'
  else
    snapshot="$(jq -c '{status: (.status // ""), metadata: (.metadata // {})}' <<<"$parent_entry")"
  fi

  # Copy the process file.
  mkdir -p "$active_cell/processes"
  cp "$src_file" "$active_cell/processes/${name}.sop.json"

  # Create the child lineage entry with forked_from set.
  local now; now="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  local new_entry; new_entry="$(jq -n --arg name "$name" --arg cell "$src_cell" --arg at "$now" --argjson snap "$snapshot" \
    '{logical_name: $name,
      forked_from: { cell: $cell, forked_at: $at, snapshot: $snap },
      history: [],
      status: "",
      metadata: {}}')"
  local child_lineage; child_lineage="$(_lineage_read "$active_cell")"
  local new_lineage; new_lineage="$(jq --arg n "$name" --argjson e "$new_entry" '.[$n] = $e' <<<"$child_lineage")"
  _lineage_write "$active_cell" "$new_lineage"

  if [[ "$OUTPUT_MODE" == "pretty" ]] || { [[ "$OUTPUT_MODE" == "auto" ]] && is_tty; }; then
    info "${C_GREEN}forked${C_RESET} '$name' from ${C_BOLD}$src_cell${C_RESET}"
    info "  into:     $active_cell/processes/${name}.sop.json"
    info "  snapshot: $snapshot"
    info "  ${C_DIM}(child's live status + metadata are empty — policy decides what to do with the snapshot)${C_RESET}"
  else
    jq -nc --arg name "$name" --arg src "$src_cell" --arg dst "$active_cell/processes/${name}.sop.json" --argjson snap "$snapshot" \
      '{ok:true, name:$name, source_cell:$src, dest_file:$dst, snapshot:$snap}'
  fi
}

# --------------------------------------------------------------------------- #
# Subcommand: help
# --------------------------------------------------------------------------- #

cmd_help() {
  cat <<EOF
${C_BOLD}opensop${C_RESET} — thin CLI for OpenSOP runtimes (v$OPENSOP_CLI_VERSION)

${C_BOLD}USAGE${C_RESET}
  opensop <command> [args]

${C_BOLD}DISCOVERY${C_RESET}
  list [--tag <tag>]            list all registered processes (optionally filtered by tag)
  search <keyword> [...]        ranked text search over process names, descriptions, tags
  suggest "<task description>"  inverse retrieval — describe a task, get a process recommendation
  schema <name>                 show the full definition of a process

${C_BOLD}INSPECTION${C_RESET}
  status <id>                   show the current state of an instance
  steps <id>                    show all steps of an instance
  diff <id1> <id2>              compare two instances of the same process
  history --process <name> [--limit N]  recent instances of a specific process (newest-first)
  compass                       top processes by run-count, recency, and failure rate

${C_BOLD}EXECUTION${C_RESET}
  run <name> [opts]             start a new instance of a process
  dry-run <name> [opts]         preview what would happen — validates inputs, no execution
  submit <id> <step-id> [opts]  submit outputs to advance a paused step
  cancel <id> [--reason TEXT]   cancel a running instance

${C_BOLD}LOCAL EXECUTION (--local — internal files, no server)${C_RESET}
  run <name|file.sop.json> --local  run a process locally; bare name resolves across the cell chain (nearest wins)
  list --local [dir]                list local processes; no arg + inside a cell walks active cell + ancestors
  runs                              list local runs
  show <run_id>                     show a local run's manifest + per-step receipts
  ${C_DIM}⚠ local steps run as shell on this machine — only run process files you trust${C_RESET}

${C_BOLD}CELLS (v0.6 — fractal addressing)${C_RESET}
  init [--name N] [--parent PATH]   create .opensop/ in cwd; parent auto-detected if cwd is inside an ancestor cell
  scope                             print the active cell + ancestor chain (errors when cwd is not inside any cell)
  annotate <skill> <type> <json>    append a policy event to the skill's lineage history in the active cell
  lineage <skill>                   print a skill's lineage entry (status, metadata, history) in the active cell
  fork <name> [--from <cell>]       copy an ancestor cell's skill into the active cell + record forked_from snapshot

${C_BOLD}AUTHORING${C_RESET}
  register <process.yaml>       POST a .sop.yaml to /sop/processes/register
  schema validate <file.yaml>   client-side YAML lint (no server round-trip)

${C_BOLD}ADMIN${C_RESET}
  instances [--state X] [--process Y]   list instances (paginated)

${C_BOLD}CONFIG${C_RESET}
  config                        show current config
  config set url <URL>          set the server URL
  config set token <TOKEN>      set the API token

${C_BOLD}GLOBAL OPTIONS${C_RESET}
  --json                        emit JSON to stdout (default when piped)
  --pretty                      pretty-print (default in TTY)
  --local                       run against internal files with no server (the local backend; see LOCAL EXECUTION)
  --help, -h                    show this help
  --version, -v                 print version

${C_BOLD}INPUT FORMS (for run/dry-run/submit)${C_RESET}
  --inputs '<json>'             pass inputs as a JSON object
  --inputs-file <path>          read inputs from a JSON file
  --input KEY=VALUE             repeatable; build the inputs object piece by piece
                                (use --outputs / --output / --outputs-file for submit)

${C_BOLD}EXAMPLES${C_RESET}
  opensop config set url https://demo.opensop.ai
  opensop config set token demo-public-token-resets-daily
  opensop list
  opensop schema lead-qualification
  opensop run lead-qualification \\
    --input lead_name="Ana García" \\
    --input lead_email=ana@example.com \\
    --input source=website
  opensop dry-run lead-qualification --input lead_name=X --input lead_email=x@y.com --input source=website
  opensop status <instance-id>
  opensop steps <instance-id>
  opensop diff <id1> <id2>
  opensop history --process lead-qualification --limit 5
  opensop compass
  opensop schema validate ./my-process.sop.yaml
  opensop register ./my-process.sop.yaml
  opensop run ./greet.sop.json --local --input name=Ana          # run locally, no server
  opensop runs                                                   # list local runs
  opensop show <run_id>                                          # local run receipts

${C_BOLD}ENVIRONMENT${C_RESET}
  OPENSOP_URL                   override config server URL for one call
  OPENSOP_TOKEN                 override config token for one call
  OPENSOP_HOME                  config + cache dir (default: ~/.opensop)
  OPENSOP_LOCAL_HOME            local-mode receipts dir (default: active cell's .opensop/ when inside a cell; else ~/.opensop-local)
  NO_COLOR                      disable ANSI color output
EOF
}

cmd_version() {
  echo "opensop $OPENSOP_CLI_VERSION"
}

# --------------------------------------------------------------------------- #
# Subcommand: config
# --------------------------------------------------------------------------- #

cmd_config() {
  if [[ $# -eq 0 ]]; then
    load_config
    if is_tty && [[ "$OUTPUT_MODE" != "json" ]]; then
      printf '%sserver:%s %s\n' "$C_BOLD" "$C_RESET" "${OPENSOP_URL:-${C_DIM}(unset)$C_RESET}"
      local masked="${OPENSOP_TOKEN:-}"
      [[ -n "$masked" ]] && masked="${masked:0:6}…${masked: -4}"
      printf '%stoken:%s  %s\n' "$C_BOLD" "$C_RESET" "${masked:-${C_DIM}(unset)$C_RESET}"
      printf '%sconfig:%s %s\n' "$C_BOLD" "$C_RESET" "$CONFIG_FILE"
    else
      jq -nc --arg url "${OPENSOP_URL:-}" --arg token "${OPENSOP_TOKEN:-}" --arg cfg "$CONFIG_FILE" \
        '{url: $url, token_set: ($token | length > 0), config: $cfg}'
    fi
    return 0
  fi

  local sub="$1"; shift
  case "$sub" in
    set)
      [[ $# -lt 2 ]] && die "usage: opensop config set <url|token> <value>" "usage_error" "run opensop help"
      local key="$1" val="$2"
      load_config
      case "$key" in
        url)   OPENSOP_URL="$val" ;;
        token) OPENSOP_TOKEN="$val" ;;
        *) die "unknown config key '$key' — valid: url, token" "usage_error" "run opensop help" ;;
      esac
      save_config
      ok "$key set"
      ;;
    *)
      die "unknown subcommand 'config $sub' — valid: set" "usage_error" "run opensop help"
      ;;
  esac
}

# --------------------------------------------------------------------------- #
# Subcommand: list
# --------------------------------------------------------------------------- #

cmd_list() {
  # --local: list internal .sop.json process files instead of server processes.
  if [[ "$LOCAL_MODE" == true ]]; then local_list "$@"; return $?; fi
  local tag_filter=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --tag) tag_filter="$2"; shift 2 ;;
      *) die "unknown flag for list: $1" "unknown_flag" "run opensop list --help" ;;
    esac
  done

  local resp; resp=$(api_get "/sop/")

  # Client-side tag filter.
  if [[ -n "$tag_filter" ]]; then
    resp=$(echo "$resp" | jq --arg tag "$tag_filter" \
      '{processes: [.processes[] | select(.tags | index($tag) != null)]}')
  fi

  if is_tty && [[ "$OUTPUT_MODE" != "json" ]]; then
    echo "$resp" | jq -r '.processes[] | "\(.name)\t\(.tags // [] | join(", "))\t\(.description // "")"' | \
      while IFS=$'\t' read -r name tags desc; do
        printf '%s%-30s%s %-40s  %s\n' "$C_BOLD" "$name" "$C_RESET" "${C_DIM}${tags}${C_RESET}" "$desc"
      done
  else
    echo "$resp" | emit_pretty_or_json
  fi
}

# --------------------------------------------------------------------------- #
# Subcommand: schema
# --------------------------------------------------------------------------- #

cmd_schema() {
  [[ $# -lt 1 ]] && die "usage: opensop schema <name>" "usage_error" "run opensop help"
  local name="$1"
  api_get "/sop/$name/schema" | emit_pretty_or_json
}

# --------------------------------------------------------------------------- #
# Subcommand: run
# --------------------------------------------------------------------------- #

# Build a JSON object from --input KEY=VALUE pairs, --inputs '<json>', or --inputs-file.
# Echoes the resulting JSON to stdout.
build_payload_object() {
  # Args:
  #   $1: noun ("input" or "output")
  #   shift; rest = the user's args after subcommand+positionals already consumed
  local noun="$1"; shift
  local plural="${noun}s"
  local json_blob=""
  local file_path=""
  local -a kv_pairs=()
  local -a metadata_pairs=()
  local extra_decided_by="" extra_confidence=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --$plural)         json_blob="$2"; shift 2 ;;
      --$plural-file)    file_path="$2"; shift 2 ;;
      --$noun)           kv_pairs+=("$2"); shift 2 ;;
      --metadata)        metadata_pairs+=("$2"); shift 2 ;;
      --decided-by)      extra_decided_by="$2"; shift 2 ;;
      --confidence)      extra_confidence="$2"; shift 2 ;;
      *)                 die "unknown flag: $1" "unknown_flag" "run opensop help" ;;
    esac
  done

  local payload="{}"

  # Start from --inputs/--outputs JSON or --inputs-file/--outputs-file.
  if [[ -n "$json_blob" ]]; then
    payload=$(echo "$json_blob" | jq .) || die "invalid JSON in --$plural" "invalid_json"
  elif [[ -n "$file_path" ]]; then
    payload=$(jq . "$file_path") || die "could not read $file_path as JSON" "invalid_json"
  fi

  # Merge --input KEY=VALUE pairs into payload.
  if (( ${#kv_pairs[@]} > 0 )); then
    for kv in "${kv_pairs[@]}"; do
      [[ "$kv" != *=* ]] && die "--$noun expects KEY=VALUE, got: $kv" "usage_error"
      local k="${kv%%=*}" v="${kv#*=}"
      # If value parses as JSON (number, bool, null, object, array), use raw; else string.
      if echo "$v" | jq -e . >/dev/null 2>&1; then
        payload=$(echo "$payload" | jq --arg k "$k" --argjson v "$v" '.[$k] = $v')
      else
        payload=$(echo "$payload" | jq --arg k "$k" --arg v "$v" '.[$k] = $v')
      fi
    done
  fi

  # Build metadata object (run only).
  local metadata="{}"
  if (( ${#metadata_pairs[@]} > 0 )); then
    for kv in "${metadata_pairs[@]}"; do
      [[ "$kv" != *=* ]] && die "--metadata expects KEY=VALUE, got: $kv" "usage_error"
      local k="${kv%%=*}" v="${kv#*=}"
      if echo "$v" | jq -e . >/dev/null 2>&1; then
        metadata=$(echo "$metadata" | jq --arg k "$k" --argjson v "$v" '.[$k] = $v')
      else
        metadata=$(echo "$metadata" | jq --arg k "$k" --arg v "$v" '.[$k] = $v')
      fi
    done
  fi

  # Emit structured response: payload + metadata + extras.
  jq -nc \
    --argjson payload "$payload" \
    --argjson metadata "$metadata" \
    --arg decided_by "$extra_decided_by" \
    --arg confidence "$extra_confidence" \
    '{payload: $payload, metadata: $metadata, decided_by: $decided_by, confidence: $confidence}'
}

cmd_run() {
  # --local: run against an internal process file (no server).
  if [[ "$LOCAL_MODE" == true ]]; then local_run "$@"; return $?; fi
  [[ $# -lt 1 ]] && die "usage: opensop run <name> [--inputs '<json>' | --input KEY=VALUE ...] [--metadata KEY=VALUE ...]" "usage_error" "run opensop help"
  local name="$1"; shift

  local built; built=$(build_payload_object input "$@")
  local inputs metadata
  inputs=$(echo "$built" | jq -c '.payload')
  metadata=$(echo "$built" | jq -c '.metadata')

  local body
  body=$(jq -nc --argjson inputs "$inputs" --argjson metadata "$metadata" \
    '{inputs: $inputs, metadata: $metadata}')

  local resp; resp=$(api_post "/sop/$name/start" "$body")
  local id state
  id=$(echo "$resp" | jq -r '.id')
  state=$(echo "$resp" | jq -r '.state')
  cache_instance "$id" "$name"

  if is_tty && [[ "$OUTPUT_MODE" != "json" ]]; then
    ok "started $C_BOLD$name$C_RESET"
    info "  id:    $id"
    info "  state: $state"
    # Show what's waiting, if anything.
    local waiting
    waiting=$(echo "$resp" | jq -r '.steps[]? | select(.state == "active") | "  \(.step_id) (\(.type)): \(.sub_state // "active")"')
    [[ -n "$waiting" ]] && { echo; printf '%swaiting:%s\n' "$C_BOLD" "$C_RESET"; echo "$waiting"; }
    echo
    info "next:  opensop status $id"
  else
    echo "$resp" | emit_pretty_or_json
  fi
}

# --------------------------------------------------------------------------- #
# Subcommand: status / steps / cancel
# --------------------------------------------------------------------------- #

cmd_status() {
  [[ $# -lt 1 ]] && die "usage: opensop status <instance-id>" "usage_error" "run opensop help"
  local id="$1"
  local name; name=$(lookup_name "$id")
  local resp; resp=$(api_get "/sop/$name/$id")

  if is_tty && [[ "$OUTPUT_MODE" != "json" ]]; then
    local state ended
    state=$(echo "$resp" | jq -r '.state')
    ended=$(echo "$resp" | jq -r '.completed_at // ""')
    local color="$C_BLUE"
    [[ "$state" == "completed" ]] && color="$C_GREEN"
    [[ "$state" == "failed"    ]] && color="$C_RED"
    [[ "$state" == "cancelled" ]] && color="$C_YELLOW"
    printf '%sinstance:%s %s\n' "$C_BOLD" "$C_RESET" "$id"
    printf '%sprocess:%s  %s\n' "$C_BOLD" "$C_RESET" "$name"
    printf '%sstate:%s    %s%s%s%s\n' "$C_BOLD" "$C_RESET" "$color" "$state" "$C_RESET" "${ended:+ ($ended)}"
    echo
    echo "$resp" | jq -r '.steps[]? | "\(.step_id)\t\(.type)\t\(.state)\t\(.sub_state // "")"' | \
      while IFS=$'\t' read -r step_id stype sstate sub; do
        local glyph
        case "$sstate" in
          completed) glyph="${C_GREEN}✓${C_RESET}" ;;
          failed)    glyph="${C_RED}✗${C_RESET}" ;;
          active)    glyph="${C_YELLOW}⏳${C_RESET}" ;;
          skipped)   glyph="${C_DIM}—${C_RESET}" ;;
          *)         glyph="${C_DIM}·${C_RESET}" ;;
        esac
        printf '  %s %-30s %s%s%s%s\n' "$glyph" "$step_id" "$C_DIM" "$stype" "${sub:+ · $sub}" "$C_RESET"
      done
  else
    echo "$resp" | emit_pretty_or_json
  fi
}

cmd_steps() {
  [[ $# -lt 1 ]] && die "usage: opensop steps <instance-id>" "usage_error" "run opensop help"
  local id="$1"
  local name; name=$(lookup_name "$id")
  api_get "/sop/$name/$id/steps" | emit_pretty_or_json
}

cmd_cancel() {
  [[ $# -lt 1 ]] && die "usage: opensop cancel <instance-id> [--reason TEXT]" "usage_error" "run opensop help"
  local id="$1"; shift
  local reason=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --reason) reason="$2"; shift 2 ;;
      *) die "unknown flag for cancel: $1" "unknown_flag" "run opensop cancel --help" ;;
    esac
  done
  local name; name=$(lookup_name "$id")
  local body
  body=$(jq -nc --arg reason "$reason" '{reason: $reason}')
  local resp; resp=$(api_post "/sop/$name/$id/cancel" "$body")

  if is_tty && [[ "$OUTPUT_MODE" != "json" ]]; then
    ok "cancelled $name $id"
    [[ -n "$reason" ]] && info "  reason: $reason"
  else
    echo "$resp" | emit_pretty_or_json
  fi
}

# --------------------------------------------------------------------------- #
# Subcommand: submit
# --------------------------------------------------------------------------- #

cmd_submit() {
  [[ $# -lt 2 ]] && die "usage: opensop submit <instance-id> <step-id> [--outputs '<json>' | --output KEY=VALUE ...] [--decided-by WHO] [--confidence N]" "usage_error" "run opensop help"
  local id="$1" step_id="$2"; shift 2

  local built; built=$(build_payload_object output "$@")
  local outputs decided_by confidence
  outputs=$(echo "$built" | jq -c '.payload')
  decided_by=$(echo "$built" | jq -r '.decided_by')
  confidence=$(echo "$built" | jq -r '.confidence')

  local body
  body=$(jq -nc --argjson outputs "$outputs" \
    --arg decided_by "$decided_by" \
    --arg confidence "$confidence" \
    '{outputs: $outputs}
     | (if $decided_by != "" then .decided_by = $decided_by else . end)
     | (if $confidence != "" then .confidence = ($confidence | tonumber) else . end)')

  local name; name=$(lookup_name "$id")
  local resp; resp=$(api_post "/sop/$name/$id/steps/$step_id/submit" "$body")

  if is_tty && [[ "$OUTPUT_MODE" != "json" ]]; then
    local instance_state step_state
    instance_state=$(echo "$resp" | jq -r '.instance.state')
    step_state=$(echo "$resp" | jq -r '.step.state')
    ok "submitted $step_id ($step_state) — instance $instance_state"
    info "next:  opensop status $id"
  else
    echo "$resp" | emit_pretty_or_json
  fi
}

# --------------------------------------------------------------------------- #
# Subcommand: instances
# --------------------------------------------------------------------------- #

cmd_instances() {
  local query=""
  local state="" process="" limit=50 offset=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --state)    state="$2";   shift 2 ;;
      --process)  process="$2"; shift 2 ;;
      --limit)    limit="$2";   shift 2 ;;
      --offset)   offset="$2";  shift 2 ;;
      *) die "unknown flag for instances: $1" "unknown_flag" "run opensop instances --help" ;;
    esac
  done
  query="?limit=$limit&offset=$offset"
  [[ -n "$state" ]]   && query="$query&state=$state"
  [[ -n "$process" ]] && query="$query&process=$process"

  local resp; resp=$(api_get "/sop/instances$query")

  # Always prime the local cache from every returned row so that
  # a subsequent `opensop status <id>` doesn't hit the cache-miss path.
  while IFS=$'\t' read -r _cid _cname; do
    [[ -n "$_cid" && -n "$_cname" ]] && cache_instance "$_cid" "$_cname"
  done < <(echo "$resp" | jq -r '.instances[]? | "\(.id)\t\(.process.name)"')

  if is_tty && [[ "$OUTPUT_MODE" != "json" ]]; then
    local total
    total=$(echo "$resp" | jq -r '.total')
    info "$total instance(s)"
    echo "$resp" | jq -r '.instances[]? | "\(.id)\t\(.process.name)\t\(.state)\t\(.started_at // "")"' | \
      while IFS=$'\t' read -r id name pstate started; do
        local color="$C_BLUE"
        [[ "$pstate" == "completed" ]] && color="$C_GREEN"
        [[ "$pstate" == "failed"    ]] && color="$C_RED"
        [[ "$pstate" == "cancelled" ]] && color="$C_YELLOW"
        printf '  %s  %-25s %s%-10s%s %s\n' "$id" "$name" "$color" "$pstate" "$C_RESET" "$C_DIM$started$C_RESET"
      done
  else
    echo "$resp" | emit_pretty_or_json
  fi
}

# --------------------------------------------------------------------------- #
# Subcommand: search / suggest — ranked text search helpers
# --------------------------------------------------------------------------- #

# score_processes KEYWORDS_JSON PROCESSES_JSON
#   Scores each process by counting case-insensitive token matches across
#   name (hyphen/underscore-tokenized) + description + tags + inputs_summary +
#   outputs_summary. Emits JSON array sorted by score desc.
#   KEYWORDS_JSON: a JSON array of strings (each may itself be multi-word;
#   they are tokenized again on whitespace inside jq).
#   PROCESSES_JSON: the full /sop/ response object.
score_processes() {
  local keywords_json="$1"
  local processes_json="$2"

  echo "$processes_json" | jq -c \
    --argjson kws "$keywords_json" '
    # Flatten a possibly-multi-word keyword array into individual tokens,
    # dropping tokens shorter than 2 characters (stop words).
    ($kws | map(ascii_downcase | split(" ") | .[] | select(length >= 2)) ) as $tokens |

    [ .processes[] |
      . as $p |
      # Build haystack:
      #   - name with hyphens/underscores replaced by spaces (tokenizes names)
      #   - description
      #   - tags joined
      #   - inputs_summary (new in v0.4.1)
      #   - outputs_summary (new in v0.4.1)
      (($p.name // "" | gsub("[-_]"; " ")) + " " +
       ($p.name // "") + " " +
       ($p.description // "") + " " +
       (($p.tags // []) | join(" ")) + " " +
       ($p.inputs_summary // "") + " " +
       ($p.outputs_summary // "")) | ascii_downcase as $text |
      # Sum word-boundary matches per token; skip tokens shorter than 2 chars.
      ($tokens | map(
        . as $tok |
        if ($tok | length) < 2 then 0
        else
          ("\\b" + $tok + "\\b") as $pat |
          ($text | [scan($pat)] | length)
        end
      ) | add // 0) as $score |
      select($score >= 1) |
      {name: $p.name, score: $score, description: ($p.description // ""), tags: ($p.tags // [])}
    ] | sort_by(-.score)
  '
}

cmd_search() {
  [[ $# -lt 1 ]] && die "usage: opensop search <keyword> [keyword2 ...]" "usage_error" "run opensop help"
  local -a keywords=("$@")
  local keywords_json
  keywords_json=$(printf '%s\n' "${keywords[@]}" | jq -Rsc '[split("\n")[] | select(length > 0)]')

  local resp; resp=$(api_get "/sop/")
  local results; results=$(score_processes "$keywords_json" "$resp")

  # Top 5 only.
  local top5; top5=$(echo "$results" | jq -c '.[0:5]')

  local count; count=$(echo "$top5" | jq 'length')
  if [[ "$count" -eq 0 ]]; then
    printf 'no matches for: %s\n' "${keywords[*]}" >&2
    exit 0
  fi

  if is_tty && [[ "$OUTPUT_MODE" != "json" ]]; then
    echo "$top5" | jq -r '.[] | "\(.score)\t\(.name)\t\(.tags | join(", "))\t\(.description)"' | \
      while IFS=$'\t' read -r score name tags desc; do
        # Truncate description to 60 chars for readability.
        local snippet="${desc:0:60}"
        [[ "${#desc}" -gt 60 ]] && snippet="${snippet}…"
        printf '%s%-4s%s  %s%-30s%s %s%s%s  %s\n' \
          "$C_DIM" "$score" "$C_RESET" \
          "$C_BOLD" "$name" "$C_RESET" \
          "$C_DIM" "(${tags})" "$C_RESET" \
          "$snippet"
      done
  else
    local query_arr; query_arr=$(printf '%s\n' "${keywords[@]}" | jq -Rsc '[split("\n")[] | select(length > 0)]')
    echo "$top5" | jq -c --argjson q "$query_arr" '{query: $q, results: .}'
  fi
}

cmd_suggest() {
  [[ $# -lt 1 ]] && die "usage: opensop suggest \"<task description>\"" "usage_error" "run opensop help"
  # Treat all positional args as one concatenated task string.
  local task="$*"
  local -a keywords
  # Split task into words.
  IFS=' ' read -r -a keywords <<< "$task"

  local threshold="0.0"
  # Check for --threshold flag: re-parse args to extract it.
  local -a remaining_args=("$@")
  local -a parsed_keywords=()
  local i=0
  while [[ $i -lt ${#remaining_args[@]} ]]; do
    local a="${remaining_args[$i]}"
    if [[ "$a" == "--threshold" ]]; then
      (( i++ ))
      threshold="${remaining_args[$i]:-0.0}"
    else
      parsed_keywords+=("$a")
    fi
    (( i++ ))
  done

  # Rebuild task and keywords from parsed args (stripping --threshold).
  if (( ${#parsed_keywords[@]} > 0 )); then
    task="${parsed_keywords[*]}"
    IFS=' ' read -r -a keywords <<< "$task"
  fi

  [[ ${#keywords[@]} -eq 0 ]] && die "usage: opensop suggest \"<task description>\"" "usage_error" "run opensop help"

  local keywords_json
  keywords_json=$(printf '%s\n' "${keywords[@]}" | jq -Rsc '[split("\n")[] | select(length > 0)]')
  local num_kws="${#keywords[@]}"

  local resp; resp=$(api_get "/sop/")
  local results; results=$(score_processes "$keywords_json" "$resp")

  # Top-1 with confidence.
  local top1; top1=$(echo "$results" | jq -c --argjson nk "$num_kws" '
    if length == 0 then null
    else
      .[0] |
      . + {confidence: ([1.0, (.score / ([$nk, 1] | max))] | min)}
    end
  ')

  if is_tty && [[ "$OUTPUT_MODE" != "json" ]]; then
    if [[ "$top1" == "null" ]]; then
      printf 'no clear match for "%s"\n' "$task"
    else
      local name confidence desc
      name=$(echo "$top1" | jq -r '.name')
      confidence=$(echo "$top1" | jq -r '.confidence | (. * 100 | round / 100 | tostring)')
      desc=$(echo "$top1" | jq -r '.description')
      # Check threshold.
      local passes; passes=$(echo "$top1" | jq -r --arg t "$threshold" '(.confidence >= ($t | tonumber)) | tostring')
      if [[ "$passes" == "true" ]]; then
        printf '%s→%s this looks like %s%s%s (confidence: %s)\n' \
          "$C_GREEN" "$C_RESET" "$C_BOLD" "$name" "$C_RESET" "$confidence"
        printf '  %s\n' "$desc"
      else
        printf 'no clear match for "%s"\n' "$task"
      fi
    fi
  else
    local match_json
    if [[ "$top1" == "null" ]]; then
      match_json="null"
    else
      # Check threshold.
      local passes; passes=$(echo "$top1" | jq -r --arg t "$threshold" '(.confidence >= ($t | tonumber)) | tostring')
      if [[ "$passes" == "true" ]]; then
        match_json=$(echo "$top1" | jq -c '{name, confidence, description}')
      else
        match_json="null"
      fi
    fi
    jq -nc --arg task "$task" --argjson match "$match_json" '{task: $task, match: $match}'
  fi
}

# --------------------------------------------------------------------------- #
# Subcommand: diff — compare two instances of the same process
# --------------------------------------------------------------------------- #

cmd_diff() {
  [[ $# -lt 2 ]] && die "usage: opensop diff <id1> <id2>" "usage_error" "run opensop help"
  local id1="$1" id2="$2"

  local name1; name1=$(lookup_name "$id1")
  local name2; name2=$(lookup_name "$id2")
  [[ "$name1" != "$name2" ]] && die "instances are from different processes ($name1 vs $name2); diff requires the same process" "cli_error"

  local a; a=$(api_get "/sop/$name1/$id1")
  local b; b=$(api_get "/sop/$name2/$id2")

  # Build structured diff in jq.
  local diff_json
  diff_json=$(jq -nc \
    --argjson a "$a" \
    --argjson b "$b" \
    --arg id1 "$id1" \
    --arg id2 "$id2" '
    def maybe_diff(p; va; vb):
      if va != vb then [{path: p, a: va, b: vb}] else [] end;

    # Top-level fields.
    (maybe_diff("state";    $a.state;   $b.state)) +
    (maybe_diff("outputs";  $a.outputs; $b.outputs)) +
    (maybe_diff("metadata"; $a.metadata; $b.metadata)) +

    # Per-step diffs — iterate step IDs, accumulate diffs per-step.
    ([$a.steps[]?.step_id, $b.steps[]?.step_id] | unique |
      map(. as $sid |
        ($a.steps[]? | select(.step_id == $sid)) as $sa |
        ($b.steps[]? | select(.step_id == $sid)) as $sb |
        maybe_diff("steps.\($sid).state";       $sa.state;       $sb.state) +
        maybe_diff("steps.\($sid).sub_state";   $sa.sub_state;   $sb.sub_state) +
        maybe_diff("steps.\($sid).outputs";     $sa.outputs;     $sb.outputs) +
        maybe_diff("steps.\($sid).decided_by";  $sa.decided_by;  $sb.decided_by) +
        maybe_diff("steps.\($sid).confidence";  $sa.confidence;  $sb.confidence) +
        maybe_diff("steps.\($sid).duration_ms"; $sa.duration_ms; $sb.duration_ms)
      ) | add // []) |

    {
      a: {id: $id1, state: $a.state, started_at: $a.started_at},
      b: {id: $id2, state: $b.state, started_at: $b.started_at},
      differences: .,
      identical: (length == 0)
    }
  ')

  if is_tty && [[ "$OUTPUT_MODE" != "json" ]]; then
    local identical; identical=$(echo "$diff_json" | jq -r '.identical')
    if [[ "$identical" == "true" ]]; then
      ok "instances are identical"
      return 0
    fi
    printf '%sdiff%s  %s  vs  %s\n\n' "$C_BOLD" "$C_RESET" "$id1" "$id2"
    echo "$diff_json" | jq -r '.differences[] | "\(.path)\t\(.a // "null")\t\(.b // "null")"' | \
      while IFS=$'\t' read -r path va vb; do
        printf '  %s%-50s%s\n' "$C_BOLD" "$path" "$C_RESET"
        printf '    %sa:%s %s\n' "$C_RED"   "$C_RESET" "$va"
        printf '    %sb:%s %s\n' "$C_GREEN" "$C_RESET" "$vb"
      done
  else
    echo "$diff_json" | emit_pretty_or_json
  fi
}

# --------------------------------------------------------------------------- #
# Subcommand: compass — top processes by runs / recency / failure rate
# --------------------------------------------------------------------------- #

cmd_compass() {
  # Paginate up to 1000 instances in batches of 200.
  local all_instances="[]"
  local offset=0 batch_size=200 fetched=0

  while true; do
    local resp; resp=$(api_get "/sop/instances?limit=${batch_size}&offset=${offset}")
    local batch; batch=$(echo "$resp" | jq -c '.instances // []')
    local count; count=$(echo "$batch" | jq 'length')
    (( count == 0 )) && break

    all_instances=$(jq -nc --argjson acc "$all_instances" --argjson new "$batch" '$acc + $new')
    (( fetched += count ))
    (( offset  += batch_size ))
    (( fetched >= 1000 || count < batch_size )) && break
  done

  # TODO: cost dimension once server exposes /sop/metrics with per-instance cost

  local stats
  stats=$(echo "$all_instances" | jq -c '
    group_by(.process.name) |
    map(
      . as $grp |
      ($grp | map(select(.state == "failed" or .state == "cancelled")) | length) as $failures |
      ($grp | length) as $total |
      {
        name:         $grp[0].process.name,
        total:        $total,
        last_run_at:  ($grp | map(.started_at) | sort | last),
        failures:     $failures,
        rate:         ($failures / $total)
      }
    ) | {
      by_runs:         (sort_by(-.total)        | .[0:10] | map({name, total})),
      by_recency:      (sort_by(.last_run_at) | reverse | .[0:10] | map({name, last_run_at})),
      by_failure_rate: (sort_by(-.rate)         | .[0:10] | map({name, total, failures, rate}))
    }
  ')

  if is_tty && [[ "$OUTPUT_MODE" != "json" ]]; then
    local by_runs by_recency by_failure
    by_runs=$(   echo "$stats" | jq -c '.by_runs')
    by_recency=$(echo "$stats" | jq -c '.by_recency')
    by_failure=$(echo "$stats" | jq -c '.by_failure_rate')

    printf '%sMost-run:%s\n' "$C_BOLD" "$C_RESET"
    echo "$by_runs" | jq -r '.[] | "  \(.name) × \(.total)"'

    printf '\n%sMost-recent:%s\n' "$C_BOLD" "$C_RESET"
    echo "$by_recency" | jq -r '.[] | "  \(.name)  \(.last_run_at // "-")"'

    printf '\n%sHighest failure rate:%s\n' "$C_BOLD" "$C_RESET"
    echo "$by_failure" | jq -r '.[] | "  \(.name)  \(.rate * 100 | round | tostring)%  (\(.failures)/\(.total))"'
  else
    echo "$stats" | emit_pretty_or_json
  fi
}

# --------------------------------------------------------------------------- #
# Subcommand: history — discoverable alias for instances --process X
# --------------------------------------------------------------------------- #

cmd_history() {
  local process="" limit=10
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --process) process="$2"; shift 2 ;;
      --limit)   limit="$2";   shift 2 ;;
      *) die "unknown flag for history: $1" "unknown_flag" "run opensop history --help" ;;
    esac
  done
  [[ -z "$process" ]] && die "usage: opensop history --process <name> [--limit N]" "usage_error" "run opensop help"
  # Delegate to cmd_instances — share backend call, no duplication.
  cmd_instances --process "$process" --limit "$limit"
}

# --------------------------------------------------------------------------- #
# Subcommand: dry-run — client-side preview, NO server execution
# --------------------------------------------------------------------------- #

# walk_steps_preview SCHEMA_JSON
#   Walks process.steps and emits a human-readable "would ..." description per step.
walk_steps_preview() {
  local schema_json="$1"
  echo "$schema_json" | jq -r '
    .process.steps[]? |
    . as $s |
    ($s.id // "?") as $id |
    ($s.type // "unknown") as $t |
    # Collect output field names; fall back to input field names for form steps.
    ([($s.outputs // [])[]?.name // empty] |
      if length == 0 then [($s.inputs // [])[]?.name // empty] else . end |
      map(select(. != null and . != "")) | join(", ")) as $fields |
    if   $t == "form" then
      "  \($id)  form          → would request input for fields: \($fields)"
    elif $t == "automated" then
      "  \($id)  automated     → would run script: \($s.run // $s.script // $s.runs // "(unspecified)")\(if $s.timeout then " (timeout: \($s.timeout)s)" else "" end)"
    elif $t == "webhook" then
      "  \($id)  webhook       → would \($s.method // "POST") \($s.url // "(unspecified)") (response_mode: \($s.response_mode // "sync"))"
    elif $t == "notification" then
      "  \($id)  notification  → would send via \($s.channel // "unspecified") to \($s.to // "(unspecified)")"
    elif $t == "judgment" then
      "  \($id)  judgment      → would route to LLM (model: \($s.model // "default"), confidence_threshold: \($s.confidence_threshold // "unset")); fallback: \($s.escalation // "none")"
    elif $t == "approval" then
      "  \($id)  approval      → would await approval from \(($s.approvers // ["(unspecified)"]) | map(tostring) | join(", "))"
    elif $t == "subprocess" then
      "  \($id)  subprocess    → would start subprocess: \($s.process // $s.name // "(unspecified)")"
    elif $t == "loop" then
      "  \($id)  loop          → would iterate over \($s.for_each_source // $s.for_each // "(unspecified)"), body: \($s.body.id // "(unspecified)")"
    elif $t == "llm" then
      "  \($id)  llm           → would call \($s.model // "default") with prompt template"
    elif $t == "wait" then
      "  \($id)  wait          → would pause for \(if $s.seconds then "\($s.seconds)s" else "(unspecified)" end)\(if $s.until then " or until \($s.until)" else "" end)"
    else
      "  \($id)  \($t)  → (unknown step type — would execute as configured)"
    end
  '
}

cmd_dry_run() {
  [[ $# -lt 1 ]] && die "usage: opensop dry-run <name> [--inputs '<json>' | --input KEY=VALUE ...] [--inputs-file <path>]" "usage_error" "run opensop help"
  local name="$1"; shift

  # Parse flags — only input flags (no metadata/etc for dry-run).
  local json_blob="" file_path=""
  local -a kv_pairs=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --inputs)       json_blob="$2";  shift 2 ;;
      --inputs-file)  file_path="$2";  shift 2 ;;
      --input)        kv_pairs+=("$2"); shift 2 ;;
      *) die "unknown flag for dry-run: $1" "unknown_flag" "run opensop dry-run --help" ;;
    esac
  done

  # Build input object.
  local inputs="{}"
  if [[ -n "$json_blob" ]]; then
    inputs=$(echo "$json_blob" | jq .) || die "invalid JSON in --inputs" "invalid_json"
  elif [[ -n "$file_path" ]]; then
    inputs=$(jq . "$file_path") || die "could not read $file_path as JSON" "invalid_json"
  fi
  if (( ${#kv_pairs[@]} > 0 )); then
    for kv in "${kv_pairs[@]}"; do
      [[ "$kv" != *=* ]] && die "--input expects KEY=VALUE, got: $kv" "usage_error"
      local k="${kv%%=*}" v="${kv#*=}"
      if echo "$v" | jq -e . >/dev/null 2>&1; then
        inputs=$(echo "$inputs" | jq --arg k "$k" --argjson v "$v" '.[$k] = $v')
      else
        inputs=$(echo "$inputs" | jq --arg k "$k" --arg v "$v" '.[$k] = $v')
      fi
    done
  fi

  # 1. Fetch schema (server round-trip for schema only, NOT execution).
  local schema; schema=$(api_get "/sop/$name/schema")

  # 2. Validate inputs against process.inputs definition.
  local errors_json
  errors_json=$(echo "$schema" | jq -c \
    --argjson supplied "$inputs" '
    [ .process.inputs[]? |
      . as $field |
      ($supplied[$field.name]) as $val |
      # Required check.
      (if ($field.required == true) and ($val == null) then
        {path: ("inputs." + $field.name), message: ("required field missing: " + $field.name)}
      else null end),
      # Type check (best-effort).
      (if $val != null then
        if   $field.type == "number"  and ($val | type) != "number"  then
          {path: ("inputs." + $field.name), message: ($field.name + " must be a number")}
        elif $field.type == "boolean" and ($val | type) != "boolean" then
          {path: ("inputs." + $field.name), message: ($field.name + " must be a boolean")}
        elif $field.type == "enum" and ($field.values != null) and ([$field.values[] | . == $val] | any | not) then
          {path: ("inputs." + $field.name), message: ($field.name + " must be one of: " + ($field.values | join(", ")))}
        elif $field.type == "string" and $field.format == "email" and ($val | type) == "string" and ($val | test("^[^@]+@[^@]+\\.[^@]+$") | not) then
          {path: ("inputs." + $field.name), message: ($field.name + " does not look like an email address")}
        else null end
      else null end)
    ] | map(select(. != null))
  ')

  local valid=true
  local err_count; err_count=$(echo "$errors_json" | jq 'length')
  (( err_count > 0 )) && valid=false

  # 3. Walk steps.
  local steps_preview
  steps_preview=$(walk_steps_preview "$schema")

  # Build per-step JSON array for JSON output.
  local steps_json
  steps_json=$(echo "$schema" | jq -c '
    [.process.steps[]? | {step_id: .id, type, preview: ("would execute \(.type) step")}]
  ')

  if is_tty && [[ "$OUTPUT_MODE" != "json" ]]; then
    printf '%sdry-run:%s %s\n\n' "$C_BOLD" "$C_RESET" "$name"

    printf '%sinputs validation:%s\n' "$C_BOLD" "$C_RESET"
    if [[ "$valid" == "true" ]]; then
      ok "inputs valid"
    else
      echo "$errors_json" | jq -r '.[] | "  ✗ \(.message)"' | sed "s/^  ✗/$(printf '%s' "${C_RED}✗${C_RESET}")/g"
      printf '%svalidation failed (%s error(s))%s\n' "$C_RED" "$err_count" "$C_RESET"
    fi

    printf '\n%sstep preview:%s\n' "$C_BOLD" "$C_RESET"
    echo "$steps_preview"
  else
    local valid_bool; valid_bool=$( [[ "$valid" == "true" ]] && echo 'true' || echo 'false')
    jq -nc \
      --arg process "$name" \
      --argjson valid "$valid_bool" \
      --argjson validation_errors "$errors_json" \
      --argjson steps "$steps_json" \
      '{process: $process, valid: $valid, validation_errors: $validation_errors, steps: $steps}'
  fi

  [[ "$valid" == "false" ]] && exit 1
  return 0
}

# --------------------------------------------------------------------------- #
# Subcommand: register — POST a .sop.yaml to /sop/processes/register
# --------------------------------------------------------------------------- #

cmd_register() {
  [[ $# -lt 1 ]] && die "usage: opensop register <process.yaml>" "usage_error" "run opensop help"
  local file="$1"
  [[ ! -f "$file" ]] && die "file does not exist: $file" "file_not_found"

  local yaml_content; yaml_content=$(cat "$file")

  # Try JSON-wrapped first; fall back to raw YAML if 4xx.
  local body; body=$(jq -nc --arg yaml "$yaml_content" '{yaml: $yaml}')
  local resp status

  # We need to capture the HTTP status to detect the fallback case.
  local tmp_resp; tmp_resp=$(mktemp)
  require_url
  local url="${OPENSOP_URL%/}/sop/processes/register"
  local -a curl_args=(-sS -X POST
    -H "Content-Type: application/json"
    -H "Accept: application/json"
    -o "$tmp_resp"
    -w "%{http_code}")
  [[ -n "${OPENSOP_TOKEN:-}" ]] && curl_args+=(-H "X-SOP-Token: $OPENSOP_TOKEN")
  curl_args+=(-d "$body")

  status=$(curl "${curl_args[@]}" "$url" 2>/dev/null || true)

  if [[ "$status" -ge 400 && "$status" -lt 500 ]]; then
    # Fall back to raw YAML body.
    curl_args=(-sS -X POST
      -H "Content-Type: application/x-yaml"
      -H "Accept: application/json"
      -o "$tmp_resp"
      -w "%{http_code}")
    [[ -n "${OPENSOP_TOKEN:-}" ]] && curl_args+=(-H "X-SOP-Token: $OPENSOP_TOKEN")
    curl_args+=(--data-binary "@$file")
    status=$(curl "${curl_args[@]}" "$url" 2>/dev/null || true)
  fi

  resp=$(cat "$tmp_resp")
  rm -f "$tmp_resp"

  if [[ "$status" -ge 400 ]]; then
    local err_code err_msg
    err_code=$(echo "$resp" | jq -r '.error // "http_error"' 2>/dev/null || echo "http_error")
    err_msg=$(echo "$resp"  | jq -r '.message // empty'      2>/dev/null || echo "")
    local emode; emode=$(_error_mode)
    if [[ "$emode" == "json" ]]; then
      jq -c --argjson s "$status" '. + {_meta: {http_status: $s}}' <<< "$resp" >&2 \
        2>/dev/null || jq -nc --argjson s "$status" \
          '{error: "http_error", message: "HTTP error", _meta: {http_status: $s}}' >&2
    else
      printf '%sopensop:%s HTTP %s — %s%s\n' "$C_RED" "$C_RESET" "$status" "$err_code" \
        "${err_msg:+: $err_msg}" >&2
      if [[ "$status" == "401" || "$status" == "403" ]]; then
        warn "registration may be admin-restricted; check your token has the right scope,"
        warn "or register via the dashboard at ${OPENSOP_URL}/admin"
      fi
    fi
    exit 1
  fi

  if is_tty && [[ "$OUTPUT_MODE" != "json" ]]; then
    local pname pversion
    pname=$(echo "$resp"    | jq -r '.process.name    // .name    // "(unknown)"' 2>/dev/null || echo "(unknown)")
    pversion=$(echo "$resp" | jq -r '.process.version // .version // "(unknown)"' 2>/dev/null || echo "(unknown)")
    ok "registered ${pname}@${pversion}"
  else
    echo "$resp" | emit_pretty_or_json
  fi
}

# --------------------------------------------------------------------------- #
# Subcommand: schema validate — fully client-side YAML lint
# --------------------------------------------------------------------------- #

# resolve_yaml FILE
#   Parses a YAML file and outputs normalized JSON. Uses yq (v4+) if available,
#   falls back to python3 + PyYAML. Exits non-zero if neither is available.
resolve_yaml() {
  local file="$1"
  if command -v yq >/dev/null 2>&1; then
    yq e -o=json '.' "$file"
  elif command -v python3 >/dev/null 2>&1; then
    python3 -c 'import yaml,json,sys; print(json.dumps(yaml.safe_load(open(sys.argv[1]))))' "$file" \
      || die "python3 YAML parse failed for $file" "parse_error"
  else
    die "schema validate needs 'yq' or 'python3' with PyYAML — install one" "missing_dependency"
  fi
}

cmd_schema_validate() {
  [[ $# -lt 1 ]] && die "usage: opensop schema validate <file.yaml>" "usage_error" "run opensop help"
  local file="$1"
  [[ ! -f "$file" ]] && die "file does not exist: $file" "file_not_found"

  local doc
  doc=$(resolve_yaml "$file") || exit 1

  local -a errors=()

  # Helper: add an error.
  add_error() { errors+=("$1"); }

  # 1. Top-level opensop field.
  local opensop_ver; opensop_ver=$(echo "$doc" | jq -r '.opensop // empty')
  [[ -z "$opensop_ver" ]] && add_error "missing top-level 'opensop' version field"

  # 2. process object.
  local has_process; has_process=$(echo "$doc" | jq 'has("process")')
  if [[ "$has_process" != "true" ]]; then
    add_error "missing top-level 'process' object"
  else
    for key in name version description; do
      local kval; kval=$(echo "$doc" | jq -r --arg k "$key" '.process[$k] // empty')
      [[ -z "$kval" ]] && add_error "process.$key is required but missing or empty"
    done

    # inputs array.
    local inputs_type; inputs_type=$(echo "$doc" | jq -r '.process.inputs | type')
    if [[ "$inputs_type" != "array" ]]; then
      add_error "process.inputs must be an array (got: $inputs_type)"
    else
      # Each input must have name + type.
      local bad_inputs
      bad_inputs=$(echo "$doc" | jq -r '
        .process.inputs | to_entries[] |
        select((.value.name == null) or (.value.type == null)) |
        "  input[\(.key)]: missing name or type"
      ')
      [[ -n "$bad_inputs" ]] && while IFS= read -r ln; do add_error "$ln"; done <<< "$bad_inputs"
    fi

    # steps array.
    local steps_type; steps_type=$(echo "$doc" | jq -r '.process.steps | type')
    if [[ "$steps_type" != "array" ]]; then
      add_error "process.steps must be an array (got: $steps_type)"
    else
      local known_types='["form","automated","judgment","approval","webhook","notification","subprocess","loop","llm","wait"]'
      # Each step: must have id + type; type must be known.
      local bad_steps
      bad_steps=$(echo "$doc" | jq -r \
        --argjson known "$known_types" '
        .process.steps | to_entries[] |
        . as $e | $e.value as $s |
        (
          (if $s.id == null then "  step[\($e.key)]: missing id" else "" end),
          (if $s.type == null then "  step[\($e.key)]: missing type" else "" end),
          (if $s.type != null and ([$known[] | . == $s.type] | any | not) then
            "  step \($s.id // $e.key): unknown type \"\($s.type)\" (valid: \($known | join(", ")))"
          else "" end)
        ) | select(length > 0)
      ')
      [[ -n "$bad_steps" ]] && while IFS= read -r ln; do add_error "$ln"; done <<< "$bad_steps"
    fi
  fi

  # 3. Validate from: reference strings — must match steps.X.outputs.Y or process.inputs.Y.
  local bad_refs
  bad_refs=$(echo "$doc" | jq -r '
    [ .. | strings | select(test("^(steps\\.[^.]+\\.outputs\\.[^.]+|process\\.inputs\\.[^.]+)$") | not)
      | select(test("^steps\\.") or test("^process\\.inputs\\.")) ] |
    map("  invalid from: reference: " + .) | .[]
  ')
  [[ -n "$bad_refs" ]] && while IFS= read -r ln; do add_error "$ln"; done <<< "$bad_refs"

  local valid=true
  (( ${#errors[@]} > 0 )) && valid=false

  if is_tty && [[ "$OUTPUT_MODE" != "json" ]]; then
    printf '%sschema validate:%s %s\n' "$C_BOLD" "$C_RESET" "$file"
    if [[ "$valid" == "true" ]]; then
      ok "valid"
    else
      for e in "${errors[@]}"; do
        printf '%s✗%s %s\n' "$C_RED" "$C_RESET" "$e"
      done
      printf '%s%s error(s) found%s\n' "$C_RED" "${#errors[@]}" "$C_RESET"
    fi
  else
    local errors_json="[]"
    if (( ${#errors[@]} > 0 )); then
      for e in "${errors[@]}"; do
        errors_json=$(echo "$errors_json" | jq --arg msg "$e" '. + [{path: "unknown", message: $msg}]')
      done
    fi
    local valid_bool; valid_bool=$( [[ "$valid" == "true" ]] && echo 'true' || echo 'false')
    jq -nc \
      --arg file "$file" \
      --argjson valid "$valid_bool" \
      --argjson errors "$errors_json" \
      '{file: $file, valid: $valid, errors: $errors}'
  fi

  [[ "$valid" == "false" ]] && exit 1
  return 0
}

# --------------------------------------------------------------------------- #
# Main dispatch
# --------------------------------------------------------------------------- #

# =========================================================================== #
# LOCAL EXECUTION ENGINE  (--local)
#
# Run a process against internal files with NO server — no Rails, no daemon, no
# network. Same CLI, two backends: `opensop run X` hits the configured server;
# `opensop run X.sop.json --local` runs X locally. Steps run in order; each gets
# the accumulated JSON context on stdin and in $OSL_CONTEXT, and its JSON stdout
# is merged back under the step id. Receipts: $OPENSOP_LOCAL_HOME/runs/<run_id>/.
# =========================================================================== #

_local_now()    { date -u +%Y-%m-%dT%H:%M:%SZ; }
# timestamp + PID + $RANDOM: distinct across processes (PID) and hardened against
# the rare same-second/recycled-PID collision. `date %N` is unportable (BSD), so
# we don't rely on sub-second precision.
_local_run_id() { echo "$(date -u +%Y%m%dT%H%M%SZ)-$$-$RANDOM"; }

# Mark a still-"running" manifest as interrupted. Registered as an EXIT trap
# during a local run so a kill/crash never leaves a run stuck at "running".
_local_finalize_trap() {
  local mf="${1:-}/manifest.json"
  [ -f "$mf" ] || return 0
  jq -e '.status=="running"' "$mf" >/dev/null 2>&1 || return 0
  jq -c '.status="interrupted"' "$mf" > "$mf.tmp" 2>/dev/null && mv "$mf.tmp" "$mf"
}

# opensop run <process.sop.json> --local [--input k=v ...]
local_run() {
  [[ $# -lt 1 ]] && die "usage: opensop run <name|process.sop.json> --local [--input KEY=VALUE ...]" "usage_error" "run opensop help"
  local proc_arg="$1"; shift

  # v0.6: argument resolution.
  #   path-shaped (contains '/' or ends in .sop.json) → use as a file path
  #   bare name → resolve across the active cell chain (nearest wins)
  local proc_file=""
  if [[ "$proc_arg" == *.sop.json ]] || [[ "$proc_arg" == */* ]]; then
    proc_file="$proc_arg"
  else
    proc_file="$(_find_skill_in_cells "$proc_arg")"
    [[ -z "$proc_file" ]] && die "skill not found: '$proc_arg' (looked in active cell + ancestors)" "file_not_found" \
        "create processes/${proc_arg}.sop.json in a cell, or pass an explicit path"
  fi

  [[ -f "$proc_file" ]] || die "process file not found: $proc_file" "file_not_found"
  jq -e . "$proc_file" >/dev/null 2>&1 || die "process file is not valid JSON: $proc_file" "invalid_json"

  local proc_dir name built inputs ctx
  proc_dir="$(cd "$(dirname "$proc_file")" && pwd)"
  name="$(jq -r '.name // "unnamed"' "$proc_file")"
  built="$(build_payload_object input "$@")"          # reuse the same input parsing as remote run
  inputs="$(echo "$built" | jq -c '.payload')"
  ctx="$(jq -c --argjson i "$inputs" '(.inputs // {}) * $i' "$proc_file")"  # declared defaults, overridden by --input

  # Validate the steps array up front — before creating a run dir — so an empty
  # or malformed process fails loudly instead of "completing" trivially.
  local n_steps
  n_steps="$(jq '(.steps // null) | if type=="array" then length else -1 end' "$proc_file")"
  [ "$n_steps" -lt 0 ] && die "process has no valid \"steps\" array: $proc_file" "parse_error" "add a \"steps\": [ ... ] array"
  [ "$n_steps" -eq 0 ] && die "process has no steps: $proc_file" "parse_error" "add at least one step to \"steps\""

  local run_id run_dir audit started
  run_id="$(_local_run_id)"; run_dir="$OPENSOP_LOCAL_HOME/runs/$run_id"
  mkdir -p "$run_dir"; audit="$run_dir/audit.jsonl"; started="$(_local_now)"
  trap '_local_finalize_trap "$run_dir"' EXIT    # safety net: never leave a run "running"
  jq -nc --arg n "$name" --arg p "$proc_file" --arg id "$run_id" --arg t "$started" --argjson inp "$ctx" \
    '{run_id:$id, process:$n, process_file:$p, started_at:$t, status:"running", inputs:$inp}' > "$run_dir/manifest.json"

  local i=0 run_status="completed"
  while [ "$i" -lt "$n_steps" ]; do
    local step sid stype srun scont
    step="$(jq -c ".steps[$i]" "$proc_file")"
    sid="$(jq -r '.id' <<<"$step")"; [ "$sid" = null ] && sid="step-$i"
    stype="$(jq -r '.type // "automated"' <<<"$step")"
    srun="$(jq -r '.run // ""' <<<"$step")"
    scont="$(jq -r '.continue_on_error // false' <<<"$step")"

    # Reset explicitly each iteration — re-`local x` (no `=`) does NOT clear a
    # value already local in this function, which would leak one step into the next.
    local out_raw="" rc=0 s_started s_ended
    s_started="$(_local_now)"
    case "$stype" in
      automated)
        local script="$srun"
        if [[ "$script" = /* ]]; then :
        elif [ -f "$proc_dir/$script" ]; then script="$proc_dir/$script"
        elif [ -f "$(cd "$proc_dir/.." 2>/dev/null && pwd)/$script" ]; then script="$(cd "$proc_dir/.." && pwd)/$script"
        else script="$proc_dir/$script"; fi
        # `|| rc=$?` is load-bearing: under `set -e` a bare `out_raw=$(failing)`
        # would abort the whole CLI here, before rc is read — killing the failure
        # receipt, manifest finalize, and continue_on_error. The `||` exempts it.
        if [ ! -f "$script" ]; then out_raw="step script not found: $script"; rc=127
        else out_raw="$(OSL_CONTEXT="$ctx" OSL_RUN_DIR="$run_dir" OSL_STEP="$sid" bash "$script" <<<"$ctx" 2>>"$run_dir/$sid.stderr.log")" || rc=$?; fi ;;
      shell)
        out_raw="$(OSL_CONTEXT="$ctx" OSL_RUN_DIR="$run_dir" OSL_STEP="$sid" bash -c "$srun" <<<"$ctx" 2>>"$run_dir/$sid.stderr.log")" || rc=$? ;;
      noop) out_raw="{}"; rc=0 ;;
      *)    out_raw="unsupported step type for local execution: $stype"; rc=2 ;;
    esac

    local out_json
    if jq -e . >/dev/null 2>&1 <<<"$out_raw"; then
      out_json="$(jq -c 'if type=="object" then . else {value:.} end' <<<"$out_raw")"
    else
      out_json="$(jq -nc --arg s "$out_raw" '{stdout:$s}')"
    fi
    s_ended="$(_local_now)"
    local sstatus; [ "$rc" -eq 0 ] && sstatus="completed" || sstatus="failed"
    # Fold the step's stderr into the receipt so `show` surfaces it; drop the
    # temp log afterwards (and never leave an empty one lying around).
    local serr=""
    [ -s "$run_dir/$sid.stderr.log" ] && serr="$(cat "$run_dir/$sid.stderr.log")"
    rm -f "$run_dir/$sid.stderr.log"
    jq -nc --arg rid "$run_id" --arg sid "$sid" --arg t "$stype" --arg st "$sstatus" --argjson rc "$rc" \
      --arg a "$s_started" --arg b "$s_ended" --argjson out "$out_json" --arg se "$serr" \
      '{run_id:$rid, step:$sid, type:$t, status:$st, exit_code:$rc, started_at:$a, ended_at:$b, output:$out}
       + (if $se=="" then {} else {stderr:$se} end)' >> "$audit"

    if [ "$rc" -eq 0 ]; then
      ctx="$(jq -c --arg id "$sid" --argjson o "$out_json" '.[$id]=$o' <<<"$ctx")"
    else
      [[ "$OUTPUT_MODE" != json ]] && err "[$sid] failed (exit $rc): $(jq -rc '.stdout // .' <<<"$out_json" | head -c 160)"
      if [ "$scont" != "true" ]; then run_status="failed"; break; fi
      ctx="$(jq -c --arg id "$sid" --argjson o "$out_json" '.[$id]=$o' <<<"$ctx")"
    fi
    i=$((i+1))
  done

  local ended; ended="$(_local_now)"
  echo "$ctx" > "$run_dir/context.json"
  jq -c --arg s "$run_status" --arg e "$ended" '.status=$s | .ended_at=$e' \
     "$run_dir/manifest.json" > "$run_dir/manifest.json.tmp" && mv "$run_dir/manifest.json.tmp" "$run_dir/manifest.json"
  trap - EXIT    # finalized normally; drop the interrupted-run safety net

  if is_tty && [[ "$OUTPUT_MODE" != "json" ]]; then
    if [ "$run_status" = completed ]; then ok "ran $C_BOLD$name$C_RESET locally — completed"; else err "ran $name locally — failed"; fi
    info "  run: $run_id"
    info "  dir: $run_dir"
    info "next:  opensop show $run_id"
  else
    jq -c . "$run_dir/manifest.json"
  fi
  [ "$run_status" = completed ]
}

# _find_skill_in_cells <name>
#   Walk the cell chain (active cell + ancestors, nearest first) looking for
#   processes/<name>.sop.json. Echo first match (nearest wins), empty if none.
_find_skill_in_cells() {
  local name="$1"
  local cell; cell="$(_find_scope_root)"
  [[ -z "$cell" ]] && return 0
  if [[ -f "$cell/processes/${name}.sop.json" ]]; then
    echo "$cell/processes/${name}.sop.json"
    return 0
  fi
  while IFS= read -r ancestor; do
    [[ -z "$ancestor" ]] && continue
    if [[ -f "$ancestor/processes/${name}.sop.json" ]]; then
      echo "$ancestor/processes/${name}.sop.json"
      return 0
    fi
  done < <(_enumerate_ancestors "$cell")
}

# opensop list --local [dir]  — discover internal .sop.json processes
#
# v0.6: when called with no arg AND cwd is inside a cell, enumerate skills
# from the active cell's processes/ then from each ancestor's processes/
# (nearest first). Tags each row with [cell-name]. When given an explicit
# dir, falls back to the original find-based behavior for backwards compat.
local_list() {
  if [[ $# -gt 0 ]]; then
    # Explicit dir: original behavior — pure find, no cell awareness
    local dir="$1"
    find "$dir" -maxdepth 2 -name '*.sop.json' 2>/dev/null | while read -r f; do
      printf "%-28s %s\n" "$(jq -r '.name // "?"' "$f" 2>/dev/null)" "$f"
    done
    return 0
  fi

  local cell; cell="$(_find_scope_root)"
  if [[ -z "$cell" ]]; then
    # Not in a cell: original cwd-scoped find
    find . -maxdepth 2 -name '*.sop.json' 2>/dev/null | while read -r f; do
      printf "%-28s %s\n" "$(jq -r '.name // "?"' "$f" 2>/dev/null)" "$f"
    done
    return 0
  fi

  # Inside a cell: walk active + ancestors, tag each with [cell-name].
  # No dedup — when a name appears in multiple cells, all rows show.
  # `opensop run <name>` resolves nearest-wins. Future: --conflicts flag.
  local d cell_name
  for d in "$cell" $(_enumerate_ancestors "$cell"); do
    [[ -d "$d/processes" ]] || continue
    cell_name="$(_read_manifest_field "$d" name)"
    while IFS= read -r f; do
      local n; n="$(jq -r '.name // "?"' "$f" 2>/dev/null)"
      printf "[%s]  %-28s %s\n" "$cell_name" "$n" "$f"
    done < <(find "$d/processes" -maxdepth 1 -name '*.sop.json' 2>/dev/null)
  done
}

# opensop runs  — list local runs (always local; the server analogue is `instances`)
local_runs() {
  [ -d "$OPENSOP_LOCAL_HOME/runs" ] || { info "(no local runs yet — opensop run <process.sop.json> --local)"; return 0; }
  for d in "$OPENSOP_LOCAL_HOME"/runs/*/; do
    [ -f "$d/manifest.json" ] || continue
    jq -r '"\(.run_id)\t\(.status)\t\(.process)\t\(.started_at)"' "$d/manifest.json"
  done | sort
}

# opensop show <run_id>  — a local run's manifest + per-step receipts
local_show() {
  local rid="${1:-}"; [ -n "$rid" ] || die "usage: opensop show <run_id>" "usage_error" "run opensop runs"
  local d="$OPENSOP_LOCAL_HOME/runs/$rid"
  [ -d "$d" ] || die "no such local run: $rid (see: opensop runs)" "instance_not_found"
  if [[ "$OUTPUT_MODE" == "json" ]]; then
    jq -nc --argjson m "$(cat "$d/manifest.json")" --argjson s "$(jq -s '.' "$d/audit.jsonl" 2>/dev/null || echo '[]')" \
      '{manifest:$m, steps:$s}'
  else
    info "── manifest ──"; jq . "$d/manifest.json"
    info "── steps ──";   jq -c '{step,status,exit_code} + (if .stderr then {stderr:(.stderr|.[0:200])} else {} end)' "$d/audit.jsonl" 2>/dev/null
  fi
}

main() {
  require_jq

  # Strip global flags (--json / --pretty / --local / --help / --version) anywhere.
  local -a args=()
  for a in "$@"; do
    case "$a" in
      --json)              OUTPUT_MODE="json" ;;
      --pretty)            OUTPUT_MODE="pretty" ;;
      --local)             LOCAL_MODE=true ;;
      --help|-h|help)      cmd_help; exit 0 ;;
      --version|-v|version) cmd_version; exit 0 ;;
      *) args+=("$a") ;;
    esac
  done

  if (( ${#args[@]} == 0 )); then
    cmd_help; exit 0
  fi
  set -- "${args[@]}"

  local cmd="$1"; shift
  load_config

  # v0.6: when cwd is inside a cell AND the user didn't explicitly set
  # OPENSOP_LOCAL_HOME, default it to the active cell's .opensop/ so
  # local-mode receipts (cmd_run / runs / show) land in the cell that
  # produced them. Explicit env override wins.
  if ! $_OPENSOP_LOCAL_HOME_EXPLICIT; then
    local _cell_for_runs; _cell_for_runs="$(_find_scope_root)"
    [[ -n "$_cell_for_runs" ]] && OPENSOP_LOCAL_HOME="$_cell_for_runs/.opensop"
  fi

  # curl is only needed for the remote (server) backend. `runs`/`show` are always
  # local, and any command with --local runs on-machine — none of them need curl.
  case "$cmd" in
    runs|show|init|scope|annotate|lineage|fork) ;;
    *) [[ "$LOCAL_MODE" == true ]] || require_curl ;;
  esac

  case "$cmd" in
    list)       cmd_list "$@" ;;
    runs)       local_runs "$@" ;;
    show)       local_show "$@" ;;
    search)     cmd_search "$@" ;;
    suggest)    cmd_suggest "$@" ;;
    schema)
      # schema can be: schema <name>  OR  schema validate <file>
      if [[ "${1:-}" == "validate" ]]; then
        shift; cmd_schema_validate "$@"
      else
        cmd_schema "$@"
      fi
      ;;
    run)        cmd_run "$@" ;;
    dry-run)    cmd_dry_run "$@" ;;
    status)     cmd_status "$@" ;;
    steps)      cmd_steps "$@" ;;
    submit)     cmd_submit "$@" ;;
    cancel)     cmd_cancel "$@" ;;
    diff)       cmd_diff "$@" ;;
    compass)    cmd_compass "$@" ;;
    history)    cmd_history "$@" ;;
    register)   cmd_register "$@" ;;
    instances)  cmd_instances "$@" ;;
    config)     cmd_config "$@" ;;
    init)       cmd_init "$@" ;;
    scope)      cmd_scope "$@" ;;
    annotate)   cmd_annotate "$@" ;;
    lineage)    cmd_lineage "$@" ;;
    fork)       cmd_fork "$@" ;;
    *)          die "unknown command '$cmd' — run 'opensop help' for usage" "unknown_command" "run opensop help" ;;
  esac
}

main "$@"
